# Production Database Connection (MySQL on CPanel)
# Format: mysql+pymysql://username:password@localhost/database_name
DATABASE_URL=mysql+pymysql://your_db_user:your_db_password@localhost/your_db_name

# Security
# Generate a secure random string for this (e.g. `openssl rand -hex 32`)
SECRET_KEY=change_this_to_a_secure_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Client Configuration
# The URL where your React frontend is hosted
ALLOWED_ORIGINS=https://linev.inphora.net,https://www.linev.inphora.net
